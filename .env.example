# Public URL where the playable web build is hosted. A same-origin path is preferred.
# VITE_GAME_URL=/game/index.html
VITE_GAME_URL=

# Optional destinations for the project calls to action.
VITE_STEAM_URL=
VITE_DEVELOPMENT_URL=

# Use a POST-capable form endpoint in production. Without it, the form opens email.
VITE_CONTACT_ENDPOINT=
VITE_CONTACT_EMAIL=hello@arrels.studio
